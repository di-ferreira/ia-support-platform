# === Environment ===
# development | production
ENVIRONMENT=development

# === Database (Supabase PostgreSQL) ===
# Dev (local Docker): PostgreSQL do Supabase via docker-compose
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
# Prod (Supabase self-hosted): mesmo host interno via Docker
DATABASE_URL_PROD=postgresql+asyncpg://postgres:postgres@supabase-db:5432/postgres

# === Auth ===
SECRET_KEY=dev-secret-key-change-in-production

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === LLM Provider ===
# ollama | openai
LLM_PROVIDER=ollama

# === OpenAI (usado apenas se LLM_PROVIDER=openai) ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === Ollama (usado se LLM_PROVIDER=ollama ou OPENAI_API_KEY vazio) ===
# URL do servidor Ollama (padrão http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
# Modelo de chat (requer: ollama pull llama3.2)
OLLAMA_MODEL=deepseek-v4-flash:cloud
# Modelo de embedding (requer: ollama pull nomic-embed-text)
OLLAMA_EMBED_MODEL=nomic-embed-text

# === Evolution API (WhatsApp) ===
# URL do servidor Evolution API
EVOLUTION_API_URL=http://localhost:8080
# Chave de autenticação global (mude em produção)
EVOLUTION_API_KEY=evolution_dev_key

# === CORS ===
CORS_ORIGINS=http://localhost:3000

# === n8n ===
N8N_PROTOCOL=http
N8N_HOST=localhost

# === Supabase ===
# Host externo do Kong (mesma porta do mapeamento em docker-compose.dev.yml)
API_EXTERNAL_URL=http://localhost:8008

# === Supabase self-hosted (produção via docker-compose.supabase.yml) ===
# Apenas para produção com stack completo. Dev usa supabase-db do docker-compose.dev.yml
JWT_SECRET=super-secret-jwt-key-change-in-production
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdEDwNnoQ9oGb2dG6o5kqE
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZxq5JzHGs6dN4eQZ8uKQjW4l2FhB1oXo7tI
# Em produção, gere chaves únicas: openssl rand -base64 32
# SUPABASE_ANON_KEY=<seu-anon-key>
# SUPABASE_SERVICE_KEY=<seu-service-key>
SUPABASE_PUBLIC_URL=http://localhost:54323
SITE_URL=http://localhost:3000
REALTIME_ENCRYPTION_KEY=supabase-realtime-encryption-key-change-in-prod
STORAGE_BUCKET=emsoft-media
