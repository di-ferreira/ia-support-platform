# === Environment ===
# development | production
ENVIRONMENT=development

# === Database ===
# Dev: SQLite (default)
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# Prod: PostgreSQL (usado pelo docker-compose.prod.yml)
DATABASE_URL_PROD=postgresql+asyncpg://emsoft:emsoft@postgres:5432/emsoft

# === Auth ===
SECRET_KEY=dev-secret-key-change-in-production

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === OpenAI ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === MinIO (S3) ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# === Evolution API (WhatsApp) ===
# URL do servidor Evolution API
EVOLUTION_API_URL=http://localhost:8080
# Chave de autenticação global (mude em produção)
EVOLUTION_API_KEY=evolution_dev_key

# === CORS ===
CORS_ORIGINS=http://localhost:3000

# === n8n ===
N8N_PROTOCOL=http
N8N_HOST=localhost
